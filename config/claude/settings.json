{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 9999,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Write(~/.claude/learnings/**)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(sudo *)",
      "Bash(mkfs *)",
      "Bash(dd if=*)",
      "Bash(git push * --force*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git commit * --no-verify*)",
      "Bash(git commit --no-verify*)",
      "Bash(cat *.env.local*)",
      "Bash(head *.env.local*)",
      "Bash(tail *.env.local*)",
      "Bash(cat *.env.*.local*)",
      "Bash(head *.env.*.local*)",
      "Bash(tail *.env.*.local*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.config/gh/hosts.yml)",
      "Read(.env.local)",
      "Read(.env.*.local)",
      "Read(**/.env.local)",
      "Read(**/.env.*.local)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Edit(~/.bash_profile)",
      "Edit(~/.zprofile)",
      "Edit(~/.profile)",
      "Edit(~/.ssh/**)",
      "Write(~/.bashrc)",
      "Write(~/.zshrc)",
      "Write(~/.bash_profile)",
      "Write(~/.zprofile)",
      "Write(~/.profile)",
      "Write(~/.ssh/**)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notification-sound.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "example-skills@anthropic-agent-skills": true,
    "security-guidance@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "dig@kuu-marketplace": true,
    "fix-ci@kuu-marketplace": true,
    "code-simplifier@claude-plugins-official": true,
    "claude-delegator@jarrodwatts-claude-delegator": true,
    "decomposition@kuu-marketplace": true,
    "document-skills@anthropic-agent-skills": true,
    "deslop@kuu-marketplace": true,
    "clarify@kuu-marketplace": true,
    "superpowers@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "aws-common@aws-skills": true,
    "aws-cdk@aws-skills": true,
    "ralph-loop@claude-plugins-official": true,
    "pm-toolkit@pm-skills": true
  },
  "extraKnownMarketplaces": {
    "pm-skills": {
      "source": {
        "source": "github",
        "repo": "phuryn/pm-skills"
      }
    }
  },
  "sandbox": {
    "network": {
      "allowedDomains": [
        "github.com"
      ]
    }
  },
  "spinnerVerbs": {
    "mode": "append",
    "verbs": [
      "うるとらしんく",
      "Thinking",
      "Processing",
      "Working"
    ]
  },
  "language": "Japanese",
  "effortLevel": "high",
  "voiceEnabled": true,
  "skipAutoPermissionPrompt": true,
  "defaultMode": "auto",
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true
}
